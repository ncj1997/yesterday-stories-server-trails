{
  "info": {
    "name": "Yesterday Stories API v2",
    "description": "Trail Management API - Change {{base_url}}, {{token}}, {{reference_code}} in collection Variables",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3001",
      "type": "default"
    },
    {
      "key": "token",
      "value": "sk_test_eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.test",
      "type": "default"
    },
    {
      "key": "reference_code",
      "value": "TRAIL-ABC123XYZ789",
      "type": "default"
    }
  ],
  "item": [
    {
      "name": "⚙️ Variables (Edit These)",
      "description": "Click this folder to see Variables tab at top - edit base_url, token, reference_code",
      "item": []
    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Draft Trails",
      "item": [
        {
          "name": "1. POST - Create Draft Trail",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"referenceCode\": \"{{reference_code}}\",\n  \"userId\": \"user-123\",\n  \"userEmail\": \"user@example.com\",\n  \"trailData\": {\n    \"title\": \"Historic Walking Tour\",\n    \"description\": \"A scenic walk through downtown\",\n    \"difficulty\": \"Easy\",\n    \"distance\": \"12.50\",\n    \"headerImages\": [\"/uploads/header-1.jpg\"],\n    \"headerVideos\": [\"/uploads/intro-video.mp4\"],\n    \"customStories\": [\n      {\n        \"title\": \"Story 1\",\n        \"description\": \"First stop on the tour\",\n        \"latitude\": -33.8688,\n        \"longitude\": 151.2093,\n        \"imageUrl\": \"/uploads/story1.jpg\",\n        \"videoUrl\": \"https://example.com/video1.mp4\"\n      }\n    ]\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/draft-trails",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "draft-trails"
              ]
            }
          }
        },
        {
          "name": "2. GET - Fetch Draft by Reference Code",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/draft-trails/{{reference_code}}",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "draft-trails",
                "{{reference_code}}"
              ]
            }
          }
        },
        {
          "name": "3. GET - Get My Drafts (AUTH REQUIRED)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/draft-trails/my-drafts",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "draft-trails",
                "my-drafts"
              ]
            }
          }
        },
        {
          "name": "4. PUT - Update Draft Data (AUTH REQUIRED)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trailData\": {\n    \"title\": \"Updated Title\",\n    \"description\": \"Updated description\",\n    \"difficulty\": \"Medium\",\n    \"distance\": \"15.75\",\n    \"headerImages\": [\"/uploads/header-1.jpg\"],\n    \"headerVideos\": [\"/uploads/updated-video.mp4\"],\n    \"customStories\": [\n      {\n        \"title\": \"Updated Story\",\n        \"description\": \"Updated story description\",\n        \"latitude\": -33.8650,\n        \"longitude\": 151.2094,\n        \"imageUrl\": \"/uploads/story-updated.jpg\"\n      }\n    ]\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/draft-trails/{{reference_code}}/update",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "draft-trails",
                "{{reference_code}}",
                "update"
              ]
            }
          }
        },
        {
          "name": "5. PUT - Mark Draft as Paid (AUTH REQUIRED)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isPaid\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/draft-trails/{{reference_code}}/paid",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "draft-trails",
                "{{reference_code}}",
                "paid"
              ]
            }
          }
        },
        {
          "name": "6. PUT - Update Draft Status (AUTH REQUIRED)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"payment_completed\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/draft-trails/{{reference_code}}/status",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "draft-trails",
                "{{reference_code}}",
                "status"
              ]
            }
          }
        },
        {
          "name": "7. DELETE - Delete Draft (AUTH REQUIRED)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/draft-trails/{{reference_code}}",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "draft-trails",
                "{{reference_code}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Published Trails",
      "item": [
        {
          "name": "GET - Get All Published Trails",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/trails?sort=distance&limit=50",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "trails"
              ],
              "query": [
                {
                  "key": "sort",
                  "value": "distance"
                },
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "POST - Create Payment Intent",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 3000,\n  \"currency\": \"AUD\",\n  \"metadata\": {\n    \"type\": \"trail\",\n    \"title\": \"Historic Walking Tour\",\n    \"referenceCode\": \"{{reference_code}}\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/payments/create-intent",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "payments",
                "create-intent"
              ]
            }
          }
        }
      ]
    }
  ]
}
