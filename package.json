{
  "name": "yesterday-stories-serverless",
  "version": "2.0.0",
  "description": "Yesterday Stories - Serverless Draft Trails & File Upload API with MySQL",
  "main": "src/index.js",
  "scripts": {
    "start": "serverless offline start",
    "dev": "nodemon --exec \"serverless offline start --httpPort 3001\" --ext js,json --ignore node_modules/",
    "dev:no-watch": "serverless offline start --httpPort 3001",
    "db:init": "node src/db/init.js",
    "deploy": "serverless deploy",
    "deploy:prod": "serverless deploy --stage prod",
    "deploy:dev": "serverless deploy --stage dev",
    "remove": "serverless remove",
    "invoke": "serverless invoke local",
    "logs": "serverless logs -f main",
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "serverless",
    "aws-lambda",
    "api-gateway",
    "draft-trails",
    "file-upload",
    "s3",
    "mysql",
    "rds"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "aws-sdk": "^2.1400.0",
    "busboy": "^1.6.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.6.0",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.5",
    "stripe": "^13.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "serverless": "^3.40.0",
    "serverless-dotenv-plugin": "^4.0.2",
    "serverless-offline": "^13.2.0"
  },
  "engines": {
    "node": "18.x || 20.x"
  }
}
